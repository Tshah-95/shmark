{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shmark",
  "version": "0.0.1",
  "identifier": "finance.shmark.desktop",
  "build": {
    "beforeDevCommand": "bun --cwd ../../frontend run dev",
    "devUrl": "http://localhost:5179",
    "beforeBuildCommand": "bun --cwd ../../frontend run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "shmark",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
